APP_IDENTIFIER=app.macbar.macbar
FASTLANE_TEAM_ID=YOUR_TEAM_ID
FASTLANE_ITC_TEAM_ID=YOUR_APP_STORE_CONNECT_TEAM_ID

# App Store Connect API key
APP_STORE_CONNECT_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_KEY_FILE=/absolute/path/AuthKey_XXXXXX.p8

# Apple account / match
FASTLANE_APPLE_ID=your-apple-id@example.com
MATCH_GIT_URL=git@github.com:YOUR_ORG/YOUR_MATCH_REPO.git
MATCH_GIT_BRANCH=main
MATCH_PASSWORD=YOUR_MATCH_ENCRYPTION_PASSWORD
MATCH_READONLY=0
